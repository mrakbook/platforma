#!/usr/bin/env bash
set -euo pipefail

PLATFORMA_ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
PLATFORMA_CONFIG_FILE="${PLATFORMA_ROOT}/tools/platforma/config.yaml"
PLATFORMA_STATE_DIR="${PLATFORMA_ROOT}/tools/platforma/state"
PLATFORMA_PIDS_DIR="${PLATFORMA_STATE_DIR}/pids"
PLATFORMA_LOGS_DIR="${PLATFORMA_STATE_DIR}/logs"

PLATFORMA_DISCOVERY_CACHE_VALID=0
PLATFORMA_DISCOVERY_CACHE=""

source "${PLATFORMA_ROOT}/tools/platforma/lib/common.sh"
source "${PLATFORMA_ROOT}/tools/platforma/core/target.sh"
source "${PLATFORMA_ROOT}/tools/platforma/tasks/run.sh"
source "${PLATFORMA_ROOT}/tools/platforma/core/platform.sh"
source "${PLATFORMA_ROOT}/tools/platforma/core/router.sh"

platforma::main "$@"
